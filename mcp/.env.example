# Dashly MCP Server configuration
# Copy this file to .env and fill in your credentials.

# Base URL of the running Dashly API
DASHLY_BASE_URL=http://localhost:3000

# Credentials used by the MCP server to authenticate with the Dashly API.
# The server logs in once on startup and caches the JWT.
DASHLY_EMAIL=admin@adsdata.com
DASHLY_PASSWORD=admin123
